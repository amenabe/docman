{% extends 'base.html.twig' %}

{% block title %}Substations{% endblock %}

{% block body %}

<h3>Substations</h3>
<table>
<thead>
<tr>
    <th>ID</th>
    <th>Code</th>
    <th>Title</th>
    <th>Description</th>
    <th>Projects</th>
</tr>
</thead>
<tbody>
{% for row in substations %}
<tr>
<td>{{ row.id }}</td>
<td>{{ row.code }}</td>
<td>{{ row.title }}</td>
<td>{{ row.description }}</td>
<td>{{ row.projects | join(', ') }}</td>
</tr>
{% endfor %}
</tbody>    
</table>
{% endblock %}
